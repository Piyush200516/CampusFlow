# Global
NODE_ENV=development
LOG_LEVEL=debug
FRONTEND_URL=http://localhost:3000

# API Gateway
API_GATEWAY_PORT=4000
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret

# Service Ports
AUTH_SERVICE_PORT=4001
USER_SERVICE_PORT=4002
ATTENDANCE_SERVICE_PORT=4003
FEE_SERVICE_PORT=4004
EVENT_SERVICE_PORT=4005
NOTIFICATION_SERVICE_PORT=4006
ACADEMIC_SERVICE_PORT=4007
LIBRARY_SERVICE_PORT=4008
DOCUMENT_SERVICE_PORT=4009

# Databases
AUTH_DATABASE_URL=postgresql://campusflow:campusflow@localhost:5432/auth_db?schema=public
USER_DATABASE_URL=postgresql://campusflow:campusflow@localhost:5433/user_db?schema=public
ATTENDANCE_DATABASE_URL=postgresql://campusflow:campusflow@localhost:5434/attendance_db?schema=public
FEE_DATABASE_URL=postgresql://campusflow:campusflow@localhost:5435/fee_db?schema=public
EVENT_DATABASE_URL=postgresql://campusflow:campusflow@localhost:5436/event_db?schema=public
LOGS_DATABASE_URL=postgresql://campusflow:campusflow@localhost:5437/logs_db?schema=public
ACADEMIC_DATABASE_URL=postgresql://campusflow:campusflow@localhost:5438/academic_db?schema=public
LIBRARY_DATABASE_URL=postgresql://campusflow:campusflow@localhost:5439/library_db?schema=public
DOCUMENT_DATABASE_URL=postgresql://campusflow:campusflow@localhost:5440/document_db?schema=public

# PostgreSQL pooling
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_POOL_IDLE_TIMEOUT_MS=30000

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=campusflow

# Queue
BULLMQ_PREFIX=campusflow
QUEUE_CONCURRENCY=5

# Email/SMS/Push
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMS_PROVIDER_API_KEY=
PUSH_PROVIDER_API_KEY=

# Payments
PAYMENT_PROVIDER=razorpay
PAYMENT_KEY_ID=
PAYMENT_KEY_SECRET=

# File Uploads
UPLOAD_MAX_FILE_SIZE_MB=20
UPLOAD_ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# Backups
BACKUP_RETENTION_DAYS=14
BACKUP_SCHEDULE_CRON=0 2 * * *
