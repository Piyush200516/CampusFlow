generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("ACADEMIC_DATABASE_URL")
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum SubmissionStatus {
  SUBMITTED
  LATE
  GRADED
  RESUBMITTED
}

enum ExamType {
  INTERNAL
  MID_SEMESTER
  END_SEMESTER
  BACKLOG
  PRACTICAL
}

enum ExamStatus {
  DRAFT
  SCHEDULED
  COMPLETED
  RESULT_PUBLISHED
  CANCELLED
}

enum LeaveStatus {
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
}

model AcademicYear {
  id        String    @id @default(uuid())
  name      String    @unique
  startsAt  DateTime
  endsAt    DateTime
  isCurrent Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([isCurrent])
  @@index([startsAt, endsAt])
  @@map("academic_years")
}

model Subject {
  id           String       @id @default(uuid())
  code         String       @unique
  name         String
  departmentId String
  courseId     String?
  semester     Int
  credits      Int          @default(3)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?
  assignments  Assignment[]
  exams        Exam[]
  timetable    TimetableSlot[]

  @@index([departmentId, courseId, semester])
  @@index([name])
  @@index([isActive, deletedAt])
  @@map("subjects")
}

model TimetableSlot {
  id           String    @id @default(uuid())
  subjectId    String
  facultyId    String
  departmentId String
  courseId     String?
  semester     Int
  section      String?
  dayOfWeek    Int
  startsAt     String
  endsAt       String
  room         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  subject      Subject   @relation(fields: [subjectId], references: [id])

  @@index([facultyId, dayOfWeek])
  @@index([departmentId, courseId, semester, section])
  @@index([deletedAt])
  @@map("timetable_slots")
}

model Assignment {
  id          String             @id @default(uuid())
  subjectId   String
  facultyId   String
  title       String
  description String?
  status      AssignmentStatus   @default(DRAFT)
  dueAt       DateTime
  maxMarks    Decimal?           @db.Decimal(6, 2)
  attachmentUrl String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?
  subject     Subject            @relation(fields: [subjectId], references: [id])
  submissions AssignmentSubmission[]

  @@index([subjectId, status])
  @@index([facultyId, createdAt])
  @@index([dueAt])
  @@index([deletedAt])
  @@map("assignments")
}

model AssignmentSubmission {
  id           String           @id @default(uuid())
  assignmentId String
  studentId    String
  status       SubmissionStatus @default(SUBMITTED)
  fileUrl      String
  remarks      String?
  marks        Decimal?         @db.Decimal(6, 2)
  submittedAt  DateTime         @default(now())
  gradedAt     DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?
  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([studentId, status])
  @@index([submittedAt])
  @@index([deletedAt])
  @@map("assignment_submissions")
}

model Exam {
  id           String       @id @default(uuid())
  subjectId    String
  academicYearId String?
  type         ExamType
  status       ExamStatus   @default(DRAFT)
  title        String
  semester     Int
  scheduledAt  DateTime
  durationMinutes Int       @default(180)
  maxMarks     Decimal      @db.Decimal(6, 2)
  createdById  String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?
  subject      Subject      @relation(fields: [subjectId], references: [id])
  results      Result[]
  admitCards   AdmitCard[]

  @@index([subjectId, type, status])
  @@index([semester, scheduledAt])
  @@index([deletedAt])
  @@map("exams")
}

model AdmitCard {
  id          String    @id @default(uuid())
  examId      String
  studentId   String
  rollNumber  String
  documentUrl String?
  issuedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  exam        Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
  @@index([studentId])
  @@index([deletedAt])
  @@map("admit_cards")
}

model Result {
  id          String    @id @default(uuid())
  examId      String
  studentId   String
  marks       Decimal   @db.Decimal(6, 2)
  grade       String?
  isBacklog   Boolean   @default(false)
  remarks     String?
  uploadedById String
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  exam        Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
  @@index([studentId, isBacklog])
  @@index([publishedAt])
  @@index([deletedAt])
  @@map("results")
}

model LeaveRequest {
  id          String      @id @default(uuid())
  facultyId   String
  reason      String
  startsAt    DateTime
  endsAt      DateTime
  status      LeaveStatus @default(SUBMITTED)
  reviewedById String?
  reviewedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  @@index([facultyId, status])
  @@index([startsAt, endsAt])
  @@index([deletedAt])
  @@map("leave_requests")
}
